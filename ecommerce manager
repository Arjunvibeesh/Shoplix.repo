<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title> SHOPLIX — Modern Goods</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #F5F2EE;
    --surface: #FFFFFF;
    --ink: #1A1714;
    --muted: #8B8580;
    --accent: #C8522A;
    --accent-light: #F2E8E3;
    --border: #E2DDD8;
    --tag-bg: #EDE9E4;
    --card-shadow: 0 2px 20px rgba(26,23,20,0.07);
    --card-shadow-hover: 0 12px 40px rgba(26,23,20,0.14);
    --radius: 12px;
    --transition: 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background-image: url('download.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;

    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
    overflow-x: hidden;
  }

  
  nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(245,242,238,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 0 clamp(16px, 5vw, 64px);
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 700; letter-spacing: -0.02em;
    color: var(--ink); text-decoration: none;
  }
  .nav-logo span { color: var(--accent); font-style: italic; }
  .nav-right { display: flex; align-items: center; gap: 24px; }
  .cart-btn {
    display: flex; align-items: center; gap: 8px;
    background: var(--ink); color: #fff;
    border: none; border-radius: 100px;
    padding: 8px 18px; font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem; font-weight: 500; cursor: pointer;
    transition: background var(--transition), transform var(--transition);
  }
  .cart-btn:hover { background: var(--accent); transform: scale(1.03); }
  .cart-count {
    background: var(--accent); color: #fff;
    border-radius: 50%; width: 20px; height: 20px;
    font-size: 0.7rem; display: flex; align-items: center; justify-content: center;
    font-weight: 700; margin-left: 2px;
    transition: transform 0.2s;
  }
  .cart-count.bump { transform: scale(1.5); }

  /* ── HERO ── */
  .hero {
    padding: clamp(48px, 8vw, 96px) clamp(16px, 5vw, 64px) clamp(32px, 5vw, 64px);
    display: flex; flex-direction: column; gap: 8px;
  }
  .hero-eyebrow {
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--accent);
  }
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    line-height: 1.08; font-weight: 700; letter-spacing: -0.02em;
    max-width: 720px;
  }
  .hero-title em { font-style: italic; color: var(--accent); }
  .hero-sub {
    color: var(--muted); font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    max-width: 480px; line-height: 1.6; margin-top: 4px;
  }

  /* ── CATEGORIES ── */
  .categories-section {
    padding: 0 clamp(16px, 5vw, 64px) 40px;
  }
  .section-label {
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--muted); margin-bottom: 14px;
  }
  .category-pills {
    display: flex; flex-wrap: wrap; gap: 10px;
  }
  .cat-pill {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 100px;
    border: 1.5px solid var(--border);
    background: var(--surface); cursor: pointer;
    font-size: 0.875rem; font-weight: 500; color: var(--muted);
    transition: all var(--transition); user-select: none;
    white-space: nowrap;
  }
  .cat-pill:hover { border-color: var(--ink); color: var(--ink); }
  .cat-pill.active {
    background: var(--ink); color: #fff; border-color: var(--ink);
  }
  .cat-pill .cat-icon { font-size: 1rem; }
  .cat-pill .cat-count {
    background: rgba(255,255,255,0.2);
    border-radius: 100px; padding: 1px 7px; font-size: 0.72rem;
  }
  .cat-pill:not(.active) .cat-count {
    background: var(--tag-bg); color: var(--muted);
  }

  /* ── TOOLBAR ── */
  .toolbar {
    padding: 0 clamp(16px, 5vw, 64px) 28px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
  }
  .toolbar-left { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .results-count { font-size: 0.875rem; color: var(--muted); }
  .results-count strong { color: var(--ink); }

  /* Filter panel */
  .filter-toggle {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 8px;
    border: 1.5px solid var(--border); background: var(--surface);
    cursor: pointer; font-size: 0.875rem; font-weight: 500; color: var(--ink);
    transition: all var(--transition);
  }
  .filter-toggle:hover { border-color: var(--ink); }
  .filter-toggle.active { border-color: var(--accent); color: var(--accent); }

  .sort-select {
    padding: 8px 14px; border-radius: 8px;
    border: 1.5px solid var(--border); background: var(--surface);
    font-size: 0.875rem; font-family: 'DM Sans', sans-serif;
    color: var(--ink); cursor: pointer; outline: none;
    transition: border-color var(--transition);
  }
  .sort-select:focus { border-color: var(--ink); }

  /* Filters Drawer */
  .filter-drawer {
    margin: 0 clamp(16px, 5vw, 64px) 24px;
    background: var(--surface); border-radius: var(--radius);
    border: 1px solid var(--border); padding: 24px;
    display: none; gap: 32px; flex-wrap: wrap;
    animation: slideDown 0.22s ease;
  }
  .filter-drawer.open { display: flex; }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .filter-group { display: flex; flex-direction: column; gap: 12px; min-width: 160px; }
  .filter-group-title {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--muted);
  }
  .filter-group label {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.875rem; cursor: pointer; color: var(--ink);
  }
  .filter-group input[type="checkbox"] {
    width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer;
  }

  /* Price range */
  .price-range-display {
    font-size: 0.875rem; font-weight: 500;
    color: var(--ink); margin-bottom: 4px;
  }
  input[type="range"] {
    width: 100%; accent-color: var(--accent); cursor: pointer;
  }

  /* Rating filter */
  .rating-stars { color: #F59E0B; font-size: 0.9rem; }

  /* ── PRODUCT GRID ── */
  .shop-layout {
    padding: 0 clamp(16px, 5vw, 64px) 80px;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }
  .product-card {
    background: var(--surface); border-radius: var(--radius);
    overflow: hidden; cursor: pointer;
    box-shadow: var(--card-shadow);
    transition: box-shadow var(--transition), transform var(--transition);
    animation: fadeIn 0.35s ease both;
    display: flex; flex-direction: column;
  }
  .product-card:hover { box-shadow: var(--card-shadow-hover); transform: translateY(-4px); }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .card-img-wrap {
    position: relative; background: var(--accent-light);
    aspect-ratio: 4/3; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    font-size: 4rem;
  }
  .card-badge {
    position: absolute; top: 12px; left: 12px;
    background: var(--accent); color: #fff;
    border-radius: 6px; padding: 3px 10px;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .card-badge.new { background: #2A7A4B; }
  .card-wishlist {
    position: absolute; top: 10px; right: 10px;
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(255,255,255,0.85); border: none;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    font-size: 1rem; transition: background var(--transition), transform var(--transition);
    backdrop-filter: blur(4px);
  }
  .card-wishlist:hover { background: #fff; transform: scale(1.15); }
  .card-wishlist.loved { color: #E53E3E; }

  .card-body { padding: 16px 18px 18px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .card-category {
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--muted);
  }
  .card-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem; line-height: 1.3; font-weight: 400;
    color: var(--ink); flex: 1;
  }
  .card-rating { display: flex; align-items: center; gap: 6px; }
  .stars { color: #F59E0B; font-size: 0.8rem; }
  .rating-count { font-size: 0.78rem; color: var(--muted); }
  .card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 4px; }
  .card-price { font-size: 1.1rem; font-weight: 600; color: var(--ink); }
  .card-price-old { text-decoration: line-through; color: var(--muted); font-size: 0.85rem; margin-right: 4px; }
  .add-btn {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--ink); color: #fff; border: none;
    font-size: 1.2rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background var(--transition), transform var(--transition);
    flex-shrink: 0;
  }
  .add-btn:hover { background: var(--accent); transform: scale(1.1); }
  .add-btn:active { transform: scale(0.96); }

  /* ── EMPTY STATE ── */
  .empty-state {
    grid-column: 1 / -1; text-align: center;
    padding: 80px 20px;
    display: flex; flex-direction: column; align-items: center; gap: 16px;
  }
  .empty-icon { font-size: 4rem; opacity: 0.4; }
  .empty-title {
    font-family: 'Playfair Display', serif; font-size: 1.5rem;
    color: var(--ink);
  }
  .empty-sub { color: var(--muted); max-width: 300px; line-height: 1.6; }

  /* ── MODAL ── */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(26,23,20,0.5);
    backdrop-filter: blur(6px);
    display: flex; align-items: flex-end; justify-content: center;
    padding: 0; opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--surface);
    border-radius: var(--radius) var(--radius) 0 0;
    padding: clamp(24px, 5vw, 48px);
    width: 100%; max-width: 640px;
    max-height: 90vh; overflow-y: auto;
    transform: translateY(40px);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }
  @media (min-width: 640px) {
    .modal-overlay { align-items: center; padding: 24px; }
    .modal { border-radius: var(--radius); max-height: 85vh; }
  }
  .modal-overlay.open .modal { transform: translateY(0); }
  .modal-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
  .modal-close {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--tag-bg); border: none; cursor: pointer;
    font-size: 1.1rem; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: background var(--transition);
  }
  .modal-close:hover { background: var(--border); }
  .modal-emoji { font-size: 5rem; text-align: center; padding: 16px 0; background: var(--accent-light); border-radius: 10px; margin-bottom: 20px; }
  .modal-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; margin-bottom: 6px; }
  .modal-category { font-size: 0.75rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px; }
  .modal-rating { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
  .modal-desc { color: var(--muted); line-height: 1.7; font-size: 0.95rem; margin-bottom: 20px; }
  .modal-price-row { display: flex; align-items: baseline; gap: 12px; margin-bottom: 24px; }
  .modal-price { font-size: 1.8rem; font-weight: 700; color: var(--ink); }
  .modal-price-old { font-size: 1.1rem; color: var(--muted); text-decoration: line-through; }
  .modal-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .tag { background: var(--tag-bg); border-radius: 100px; padding: 5px 14px; font-size: 0.8rem; color: var(--muted); }
  .modal-add-btn {
    width: 100%; padding: 14px; border-radius: var(--radius);
    background: var(--ink); color: #fff; border: none;
    font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 600;
    cursor: pointer; transition: background var(--transition), transform var(--transition);
    letter-spacing: 0.02em;
  }
  .modal-add-btn:hover { background: var(--accent); transform: scale(1.01); }

  /* ── CART DRAWER ── */
  .cart-overlay {
    position: fixed; inset: 0; z-index: 300;
    background: rgba(26,23,20,0.4); backdrop-filter: blur(4px);
    opacity: 0; pointer-events: none; transition: opacity 0.3s;
  }
  .cart-overlay.open { opacity: 1; pointer-events: all; }
  .cart-drawer {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(400px, 100vw);
    background: var(--surface);
    box-shadow: -8px 0 40px rgba(0,0,0,0.12);
    display: flex; flex-direction: column;
    transform: translateX(100%); transition: transform 0.32s cubic-bezier(0.4,0,0.2,1);
    z-index: 301;
  }
  .cart-drawer.open { transform: translateX(0); }
  .cart-header {
    padding: 24px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .cart-title { font-family: 'Playfair Display', serif; font-size: 1.3rem; }
  .cart-close {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--tag-bg); border: none; cursor: pointer; font-size: 1.1rem;
    display: flex; align-items: center; justify-content: center;
    transition: background var(--transition);
  }
  .cart-close:hover { background: var(--border); }
  .cart-items { flex: 1; overflow-y: auto; padding: 16px 24px; display: flex; flex-direction: column; gap: 16px; }
  .cart-item {
    display: flex; gap: 14px; align-items: center;
    padding: 14px; background: var(--bg); border-radius: 10px;
    animation: fadeIn 0.2s ease;
  }
  .cart-item-emoji { font-size: 2rem; width: 48px; height: 48px; background: var(--accent-light); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .cart-item-info { flex: 1; min-width: 0; }
  .cart-item-name { font-size: 0.9rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .cart-item-price { font-size: 0.85rem; color: var(--muted); margin-top: 2px; }
  .cart-item-controls { display: flex; align-items: center; gap: 8px; }
  .qty-btn { width: 26px; height: 26px; border-radius: 50%; border: 1.5px solid var(--border); background: var(--surface); cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; transition: all var(--transition); }
  .qty-btn:hover { border-color: var(--ink); }
  .qty-num { font-size: 0.9rem; font-weight: 600; min-width: 20px; text-align: center; }
  .cart-footer { padding: 20px 24px; border-top: 1px solid var(--border); }
  .cart-summary { display: flex; justify-content: space-between; margin-bottom: 16px; }
  .cart-total-label { font-size: 0.875rem; color: var(--muted); }
  .cart-total-price { font-size: 1.2rem; font-weight: 700; }
  .checkout-btn {
    width: 100%; padding: 14px; border-radius: var(--radius);
    background: var(--accent); color: #fff; border: none;
    font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 600;
    cursor: pointer; transition: opacity var(--transition), transform var(--transition);
  }
  .checkout-btn:hover { opacity: 0.88; transform: scale(1.01); }
  .cart-empty-msg { text-align: center; padding: 48px 0; color: var(--muted); }
  .cart-empty-msg .empty-icon { font-size: 3rem; display: block; margin-bottom: 12px; opacity: 0.4; }

  /* ── TOAST ── */
  .toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--ink); color: #fff;
    padding: 12px 22px; border-radius: 100px;
    font-size: 0.875rem; font-weight: 500;
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    z-index: 400; transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), opacity 0.3s;
    opacity: 0; white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 24px clamp(16px, 5vw, 64px);
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;
    font-size: 0.8rem; color: var(--muted);
  }
  .footer-logo { font-family: 'Playfair Display', serif; font-weight: 700; color: var(--ink); }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    .hero-title { font-size: 2rem; }
    .product-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .card-body { padding: 12px 14px 14px; }
    .card-name { font-size: 0.9rem; }
  }
  @media (max-width: 400px) {
    .product-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="#">SHOPLIX<span>.</span></a>
  <div class="nav-right">
    <button class="cart-btn" id="cartToggle">
      🛍 Cart <span class="cart-count" id="cartCount">0</span>
    </button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-eyebrow">Minimal. Modern. Timeless.</div>
  <h1 class="hero-title">Curated goods<br>for <em>modern</em> living.</h1>
  <p class="hero-sub">Thoughtfully selected electronics, fashion, and accessories for those who value quality over quantity.</p>
</section>

<!-- CATEGORIES -->
<section class="categories-section">
  <div class="section-label">Browse by category</div>
  <div class="category-pills" id="categoryPills"></div>
</section>

<!-- TOOLBAR -->
<div class="toolbar">
  <div class="toolbar-left">
    <span class="results-count" id="resultsCount"></span>
    <button class="filter-toggle" id="filterToggle">⚙ Filters</button>
  </div>
  <select class="sort-select" id="sortSelect">
    <option value="default">Sort: Featured</option>
    <option value="price-asc">Price: Low to High</option>
    <option value="price-desc">Price: High to Low</option>
    <option value="rating">Top Rated</option>
    <option value="name">Name A–Z</option>
  </select>
</div>

<!-- FILTER DRAWER -->
<div class="filter-drawer" id="filterDrawer">
  <div class="filter-group">
    <div class="filter-group-title">Price Range</div>
    <div class="price-range-display" id="priceDisplay">Up to ₹<span id="priceVal">50000</span></div>
    <input type="range" id="priceRange" min="0" max="50000" step="500" value="50000">
  </div>
  <div class="filter-group">
    <div class="filter-group-title">Minimum Rating</div>
    <label><input type="radio" name="rating" value="0" checked> All ratings</label>
    <label><input type="radio" name="rating" value="4"> <span class="rating-stars">★★★★</span> & up</label>
    <label><input type="radio" name="rating" value="4.5"> <span class="rating-stars">★★★★★</span> only</label>
  </div>
  <div class="filter-group">
    <div class="filter-group-title">Availability</div>
    <label><input type="checkbox" id="filterSale"> On Sale</label>
    <label><input type="checkbox" id="filterNew"> New Arrivals</label>
  </div>
</div>

<!-- GRID -->
<main class="shop-layout">
  <div class="product-grid" id="productGrid"></div>
</main>

<!-- FOOTER -->
<footer>
  <span class="footer-logo">SHOPLIX.</span>
  <span>© 2026 SHOPLIX. All rights reserved.</span>
</footer>

<!-- PRODUCT MODAL -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal" id="productModal"></div>
</div>

<!-- CART DRAWER -->
<div class="cart-overlay" id="cartOverlay"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-header">
    <div class="cart-title">Your Cart</div>
    <button class="cart-close" id="cartClose">✕</button>
  </div>
  <div class="cart-items" id="cartItems"></div>
  <div class="cart-footer">
    <div class="cart-summary">
      <span class="cart-total-label">Total</span>
      <span class="cart-total-price" id="cartTotal">₹0</span>
    </div>
    <button class="checkout-btn" id="checkoutBtn">Proceed to Checkout →</button>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ─── DATA ───────────────────────────────────────────────────────────────
const categories = [
  { id: 'all', label: 'All Products', icon: '🏪' },
  { id: 'electronics', label: 'Electronics', icon: '💻' },
  { id: 'clothing', label: 'Clothing', icon: '👕' },
  { id: 'accessories', label: 'Accessories', icon: '💍' },
  { id: 'home', label: 'Home & Living', icon: '🏠' },
  { id: 'sports', label: 'Sports', icon: '🏃' },
];

const products = [
  // Electronics
