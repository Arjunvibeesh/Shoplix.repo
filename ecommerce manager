// ─── STATE ───────────────────────────────────────────────────────────────
let state = {
  activeCategory: 'all',
  maxPrice: 50000,
  minRating: 0,
  onlySale: false,
  onlyNew: false,
  sort: 'default',
  cart: [],
  wishlist: new Set(),
};

// ─── CART ────────────────────────────────────────────────────────────────
function addToCart(productId) {
  const p = products.find(x => x.id === productId);
  const existing = state.cart.find(x => x.id === productId);
  if (existing) existing.qty++;
  else state.cart.push({ ...p, qty: 1 });
  renderCart();
  showToast(`${p.emoji} Added to cart!`);
  bumpCount();
}

function removeFromCart(id) { state.cart = state.cart.filter(x => x.id !== id); renderCart(); }
function changeQty(id, delta) {
  const item = state.cart.find(x => x.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty < 1) removeFromCart(id);
  else renderCart();
}

function renderCart() {
  const el = document.getElementById('cartItems');
  const countEl = document.getElementById('cartCount');
  const totalEl = document.getElementById('cartTotal');
  const total = state.cart.reduce((s, x) => s + x.price * x.qty, 0);
  const count = state.cart.reduce((s, x) => s + x.qty, 0);
  countEl.textContent = count;
  totalEl.textContent = '₹' + total.toLocaleString('en-IN');
  if (state.cart.length === 0) {
    el.innerHTML = `<div class="cart-empty-msg"><span class="empty-icon">🛍️</span>Your cart is empty.<br>Browse and add something lovely!</div>`;
    return;
  }
  el.innerHTML = state.cart.map(item => `
    <div class="cart-item">
      <div class="cart-item-emoji">${item.emoji}</div>
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-price">₹${(item.price * item.qty).toLocaleString('en-IN')}</div>
      </div>
      <div class="cart-item-controls">
        <button class="qty-btn" onclick="changeQty(${item.id},-1)">−</button>
        <span class="qty-num">${item.qty}</span>
        <button class="qty-btn" onclick="changeQty(${item.id},1)">+</button>
      </div>
    </div>
  `).join('');
}

function bumpCount() {
  const el = document.getElementById('cartCount');
  el.classList.add('bump');
  setTimeout(() => el.classList.remove('bump'), 300);
}

// ─── WISHLIST ────────────────────────────────────────────────────────────
function toggleWishlist(id) {
  if (state.wishlist.has(id)) state.wishlist.delete(id);
  else { state.wishlist.add(id); showToast('💛 Saved to wishlist!'); }
  renderGrid();
}

// ─── FILTERS & SORT ──────────────────────────────────────────────────────
function getFiltered() {
  let list = [...products];
  if (state.activeCategory !== 'all') list = list.filter(p => p.category === state.activeCategory);
  list = list.filter(p => p.price <= state.maxPrice);
  list = list.filter(p => p.rating >= state.minRating);
  if (state.onlySale) list = list.filter(p => p.badge === 'sale');
  if (state.onlyNew) list = list.filter(p => p.badge === 'new');
  // Sort
  if (state.sort === 'price-asc') list.sort((a, b) => a.price - b.price);
  else if (state.sort === 'price-desc') list.sort((a, b) => b.price - a.price);
  else if (state.sort === 'rating') list.sort((a, b) => b.rating - a.rating);
  else if (state.sort === 'name') list.sort((a, b) => a.name.localeCompare(b.name));
  return list;
}

function renderGrid() {
  const list = getFiltered();
  const grid = document.getElementById('productGrid');
  document.getElementById('resultsCount').innerHTML = `<strong>${list.length}</strong> product${list.length !== 1 ? 's' : ''}`;
  if (list.length === 0) {
    grid.innerHTML = `<div class="empty-state"><div class="empty-icon">🔍</div><div class="empty-title">No products found</div><p class="empty-sub">Try adjusting your filters or browse a different category.</p></div>`;
    return;
  }
  grid.innerHTML = list.map((p, i) => {
    const loved = state.wishlist.has(p.id);
    const stars = '★'.repeat(Math.round(p.rating)) + '☆'.repeat(5 - Math.round(p.rating));
    const badge = p.badge ? `<div class="card-badge ${p.badge === 'new' ? 'new' : ''}">${p.badge === 'sale' ? 'Sale' : 'New'}</div>` : '';
    const oldPrice = p.oldPrice ? `<span class="card-price-old">₹${p.oldPrice.toLocaleString('en-IN')}</span>` : '';
    return `
    <div class="product-card" style="animation-delay:${i * 40}ms" onclick="openModal(${p.id})">
      <div class="card-img-wrap">
        ${badge}
        <span style="font-size:3.5rem">${p.emoji}</span>
        <button class="card-wishlist ${loved ? 'loved' : ''}" onclick="event.stopPropagation();toggleWishlist(${p.id})" title="${loved ? 'Remove from wishlist' : 'Save to wishlist'}">
          ${loved ? '❤️' : '🤍'}
        </button>
      </div>
      <div class="card-body">
        <div class="card-category">${categories.find(c=>c.id===p.category)?.label || p.category}</div>
        <div class="card-name">${p.name}</div>
        <div class="card-rating">
          <span class="stars">${stars}</span>
          <span class="rating-count">${p.rating} (${p.reviews})</span>
        </div>
        <div class="card-footer">
          <div>${oldPrice}<span class="card-price">₹${p.price.toLocaleString('en-IN')}</span></div>
          <button class="add-btn" onclick="event.stopPropagation();addToCart(${p.id})" title="Add to cart">+</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function renderCategories() {
  const pills = document.getElementById('categoryPills');
  const counts = {};
  products.forEach(p => { counts[p.category] = (counts[p.category] || 0) + 1; });
  pills.innerHTML = categories.map(c => {
    const count = c.id === 'all' ? products.length : (counts[c.id] || 0);
    const active = state.activeCategory === c.id ? 'active' : '';
    return `<button class="cat-pill ${active}" onclick="selectCategory('${c.id}')">
      <span class="cat-icon">${c.icon}</span>
      ${c.label}
      <span class="cat-count">${count}</span>
    </button>`;
  }).join('');
}

function selectCategory(id) {
  state.activeCategory = id;
  renderCategories();
  renderGrid();
}

// ─── MODAL ───────────────────────────────────────────────────────────────
function openModal(id) {
  const p = products.find(x => x.id === id);
  const overlay = document.getElementById('modalOverlay');
  const modal = document.getElementById('productModal');
  const stars = '★'.repeat(Math.round(p.rating)) + '☆'.repeat(5 - Math.round(p.rating));
  const oldPrice = p.oldPrice ? `<span class="modal-price-old">₹${p.oldPrice.toLocaleString('en-IN')}</span>` : '';
  const badge = p.badge ? `<div class="card-badge ${p.badge==='new'?'new':''}" style="display:inline-block;margin-bottom:8px">${p.badge==='sale'?'On Sale':'New Arrival'}</div>` : '';
  modal.innerHTML = `
    <div class="modal-header">
      <div>${badge}</div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-emoji">${p.emoji}</div>
    <div class="modal-category">${categories.find(c=>c.id===p.category)?.label}</div>
    <div class="modal-title">${p.name}</div>
    <div class="modal-rating">
      <span class="stars" style="color:#F59E0B">${stars}</span>
      <span style="font-size:0.85rem;color:var(--muted)">${p.rating} · ${p.reviews} reviews</span>
    </div>
    <p class="modal-desc">${p.desc}</p>
    <div class="modal-price-row">
      <span class="modal-price">₹${p.price.toLocaleString('en-IN')}</span>
      ${oldPrice}
    </div>
    <div class="modal-tags">${p.tags.map(t=>`<span class="tag">#${t}</span>`).join('')}</div>
    <button class="modal-add-btn" onclick="addToCart(${p.id});closeModal()">Add to Cart — ₹${p.price.toLocaleString('en-IN')}</button>
  `;
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

// ─── TOAST ───────────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}

// ─── EVENT LISTENERS ─────────────────────────────────────────────────────
document.getElementById('priceRange').addEventListener('input', e => {
  state.maxPrice = +e.target.value;
  document.getElementById('priceVal').textContent = (+e.target.value).toLocaleString('en-IN');
  renderGrid();
});

document.querySelectorAll('input[name="rating"]').forEach(r =>
  r.addEventListener('change', e => { state.minRating = +e.target.value; renderGrid(); })
);

document.getElementById('filterSale').addEventListener('change', e => { state.onlySale = e.target.checked; renderGrid(); });
document.getElementById('filterNew').addEventListener('change', e => { state.onlyNew = e.target.checked; renderGrid(); });
document.getElementById('sortSelect').addEventListener('change', e => { state.sort = e.target.value; renderGrid(); });

document.getElementById('filterToggle').addEventListener('click', () => {
  const drawer = document.getElementById('filterDrawer');
  const btn = document.getElementById('filterToggle');
  drawer.classList.toggle('open');
  btn.classList.toggle('active');
});

// Cart
document.getElementById('cartToggle').addEventListener('click', () => {
  document.getElementById('cartDrawer').classList.add('open');
  document.getElementById('cartOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
});
function closeCart() {
  document.getElementById('cartDrawer').classList.remove('open');
  document.getElementById('cartOverlay').classList.remove('open');
  document.body.style.overflow = '';
}
document.getElementById('cartClose').addEventListener('click', closeCart);
document.getElementById('cartOverlay').addEventListener('click', closeCart);
document.getElementById('checkoutBtn').addEventListener('click', () => {
  if (state.cart.length === 0) { showToast('Your cart is empty!'); return; }
  showToast('🎉 Order placed! Thank you for shopping.');
  state.cart = [];
  renderCart();
  closeCart();
});

// Modal close
document.getElementById('modalOverlay').addEventListener('click', e => {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
});

// ─── INIT ────────────────────────────────────────────────────────────────
renderCategories();
renderGrid();
renderCart();
</script>
</body>
